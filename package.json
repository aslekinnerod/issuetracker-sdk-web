{
  "name": "@issuetracker/sdk-web",
  "version": "0.4.0",
  "description": "Drop-in issue reporter SDK for web apps. Shake-equivalent triggers, screenshot capture, annotation, breadcrumbs, crash detection.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "unpkg": "./dist/index.global.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "example": "vite serve example"
  },
  "dependencies": {
    "html2canvas": "^1.4.1"
  },
  "devDependencies": {
    "tsup": "^8.3.5",
    "typescript": "^5.6.3",
    "vite": "^6.0.3"
  },
  "engines": {
    "node": ">=18"
  },
  "license": "MIT"
}
