{
  "name": "@issuetracker/sdk-web",
  "version": "0.5.3",
  "description": "Drop-in issue reporter SDK for web apps. Shake-equivalent triggers, screenshot capture, annotation, breadcrumbs, crash detection.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "unpkg": "./dist/index.global.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "example": "vite serve example",
    "prepare": "tsup"
  },
  "dependencies": {
    "html2canvas": "^1.4.1"
  },
  "devDependencies": {
    "happy-dom": "^15.7.4",
    "tsup": "^8.3.5",
    "typescript": "^5.6.3",
    "vite": "^6.0.3",
    "vitest": "^2.1.5"
  },
  "engines": {
    "node": ">=18"
  },
  "license": "MIT"
}
